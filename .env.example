# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# AI Provider Configuration (set ONE of the following):

# Option 1: OpenAI - Get your API Key here: https://platform.openai.com/api-keys
# Uses: gpt-4o (chat), o3-mini (reasoning), gpt-4o-mini (titles/artifacts), dall-e-3 (images)
OPENAI_API_KEY=****

# Option 2: Google Gemini - Get your free API Key here: https://aistudio.google.com/apikey
# Uses: gemini-2.0-flash (chat, reasoning, titles/artifacts)
# Note: If OPENAI_API_KEY is set, it takes priority over GOOGLE_GENERATIVE_AI_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=****

# Option 3: xAI (Grok) - Get your API Key here: https://console.x.ai/
# Uses: grok-2-vision-1212 (chat), grok-3-mini-beta (reasoning), grok-2-1212 (titles/artifacts), grok-2-image (images)
# Note: If OPENAI_API_KEY or GOOGLE_GENERATIVE_AI_API_KEY is set, they take priority over XAI_API_KEY
XAI_API_KEY=****

# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/storage/vercel-postgres/quickstart
POSTGRES_URL=****

# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****
